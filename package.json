{
  "name": "@tswjs/tsw",
  "version": "2.0.0-alpha.10",
  "description": "A Node.js infrastructure which is designed for improving the efficiency of locating problems, providing multiple functions for front-end developers",
  "main": "dist/index.js",
  "bin": {
    "tsw": "dist/cli.js"
  },
  "scripts": {
    "commitlint": "commitlint --color",
    "test": "jest --coverage",
    "build": "tsc",
    "dev": "tsc --watch --sourceMap",
    "lint": "eslint --ext .ts .",
    "lint:fix": "eslint --fix --ext .ts .",
    "benchmark": "cd benchmark && make",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tencent/TSW.git"
  },
  "keywords": [
    "tsw"
  ],
  "engines": {
    "node": ">= 12.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/exec": "^7.0.0",
    "@types/ip": "^1.1.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "husky": "^9.0.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.ts": "yarn lint:fix"
  },
  "dependencies": {
    "chalk": "^3.0.0",
    "ip": "^1.1.5",
    "lodash": "^4.17.15",
    "moment": "^2.24.0",
    "winston": "^3.2.1",
    "winston-transport": "^4.3.0",
    "yargs": "^15.3.1"
  }
}
